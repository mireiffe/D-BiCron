{
  "source": "my_postgres",
  "target": "my_clickhouse",
  "api": {
    "base_url": "https://api.example.com/v1/predict",
    "method": "POST",
    "headers": {
      "Authorization": "Bearer ${API_TOKEN}"
    },
    "timeout_seconds": 30,
    "mode": "per_row",
    "max_workers": 4,

    "request_body_template": {
      "model_id": "classifier-v2",
      "inputs": {
        "text": "{description}",
        "images": "$collections.product_images",
        "metadata": {
          "category": "{category_name}",
          "source_id": "{id}"
        }
      }
    },

    "response_merge": [
      { "json_path": "predictions", "prefix": "pred" },
      { "json_path": "confidence_scores", "prefix": "conf" }
    ]
  },
  "defaults": {
    "engine": "MergeTree",
    "batch_size": 500,
    "timestamp_column": "_enriched_at"
  },
  "tables": [
    {
      "source_table": "public.products",
      "source_columns": {
        "id": "Int64",
        "sku": "String"
      },
      "watermark_column": "updated_at",
      "overlap_minutes": 30,

      "source_queries": [
        {
          "name": "product_details",
          "db": "my_postgres",
          "sql": "SELECT description, category_name FROM public.product_details WHERE product_id = :id",
          "bind_from": "source"
        }
      ],

      "s3_objects": {
        "endpoint_url": "${S3_ENDPOINT}",
        "access_key": "${S3_ACCESS_KEY}",
        "secret_key": "${S3_SECRET_KEY}",
        "bucket": "${S3_BUCKET}",
        "prefix_template": "products/{sku}/images/",
        "group_by_substring": {
          "product_images": "photo_",
          "diagrams": "diagram_"
        },
        "encoding": "base64",
        "max_object_size_bytes": 10485760,
        "on_failure": "skip_object"
      },

      "exclusion": {
        "enabled": true,
        "key_column": "id",
        "target_key_column": "id"
      },

      "target_table": "default.product_predictions",
      "timestamp_column": "_enriched_at",
      "response_mapping": [
        { "json_path": "pred.label",  "column": "prediction", "type": "String" },
        { "json_path": "conf",        "column": "confidence",  "type": "Float64" }
      ],

      "write_strategy": "upsert",
      "upsert_key_columns": ["id"],

      "child_targets": [
        {
          "target_table": "default.prediction_details",
          "parent_key_column": "id",
          "foreign_key_column": "parent_id",
          "source_array_path": "details",
          "response_mapping": [
            { "json_path": "tag",   "column": "tag",   "type": "String" },
            { "json_path": "value", "column": "value",  "type": "Float64" }
          ],
          "write_strategy": "insert",
          "engine": "MergeTree",
          "order_by": ["parent_id", "tag"]
        }
      ],

      "engine": "ReplacingMergeTree(_enriched_at)",
      "order_by": ["id"],
      "partition_by": "toYYYYMM(_enriched_at)",
      "batch_size": 50
    }
  ]
}
