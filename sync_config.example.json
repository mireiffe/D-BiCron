{
  "_comment": "source/target 생략 시 .env 의 SUSDB_*/COREDB_* 사용",
  "source": {
    "host": "source-db.example.com",
    "port": 5432,
    "database": "production",
    "user": "reader",
    "password": "secret"
  },
  "target": {
    "host": "target-db.example.com",
    "port": 5432,
    "database": "analytics",
    "user": "writer",
    "password": "secret"
  },
  "tables": [
    {
      "table": "device_master",
      "pk_columns": ["id"],
      "ts_column": "updated_at",
      "source_schema": "public",
      "target_schema": "public"
    },
    {
      "table": "sensor_readings",
      "pk_columns": ["device_id", "measured_at"],
      "ts_column": "created_at",
      "overlap_minutes": 60
    }
  ]
}
