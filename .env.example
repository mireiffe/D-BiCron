# susdb (source)
SUSDB_HOST=localhost
SUSDB_PORT=5432
SUSDB_DBNAME=susdb
SUSDB_USER=
SUSDB_PASSWORD=

# coredb (target)
COREDB_HOST=localhost
COREDB_PORT=5432
COREDB_DBNAME=coredb
COREDB_USER=
COREDB_PASSWORD=

# Team Vibe Check (comma-separated names)
TEAM_MEMBERS=Alice,Bob,Charlie

# Incremental Sync (path to JSON config)
SYNC_CONFIG=sync_config.json

# Pipeline canvas config (path to JSON)
PIPELINE_CONFIG=pipeline_config.json

# History / log retention (hours, default 168 = 7 days)
HISTORY_RETENTION_HOURS=168

# Webhook URL for job failure notifications (Slack, Discord, etc.)
WEBHOOK_URL=

# Job execution safety
JOB_TIMEOUT_MS=1800000
JOB_MAX_RETRIES=0

# S3-compatible storage
S3_ENDPOINT_URL=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_NAME=
